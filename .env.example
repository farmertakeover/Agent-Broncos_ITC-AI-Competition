# Flask loads `.env` only (see app/__init__.py load_dotenv). This file is a template — copy to `.env`:
#   cp .env.example .env
# =============================================================================
# Recommended: Ollama Cloud — LLM runs on Ollama’s hosts; keeps ~8 GiB laptop RAM
# for Flask, FAISS, faster-whisper, browser, etc.
# Docs: https://docs.ollama.com/cloud — API key: https://ollama.com/settings/keys
# Cloud model list: https://ollama.com/search?c=cloud
# =============================================================================
OLLAMA_BASE_URL=https://ollama.com
# Never commit real keys. Put the key only in `.env` (gitignored) or CI secrets — not in source.
OLLAMA_API_KEY=replace_with_your_ollama_api_key
# Example cloud tag (use what `ollama.com/search?c=cloud` lists for your account, e.g. gemma3:4b).
# Smaller cloud models (e.g. gemma3:4b) — pair with the “stability” block below.
OLLAMA_MODEL=gemma3:4b

# 1) Start Flask first:  python run.py
# 2) Verify (needs network; key must be valid):
#   export $(grep -v '^#' .env | xargs)   # optional: load .env into shell for curl
#   curl -sS -H "Authorization: Bearer $OLLAMA_API_KEY" https://ollama.com/api/tags | head
#   curl -sS http://127.0.0.1:5000/api/health | python3 -m json.tool
# Expect: ollama_reachable true, ollama_host_is_cloud true, ollama_model_present true

# CPP_LLM_BACKEND=ollama

# =============================================================================
# Alternative: local Ollama (uses laptop RAM for the GGUF)
# =============================================================================
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=gemma3:4b
# Leave OLLAMA_API_KEY unset for local, or set only if your daemon requires auth.

# Remote self-hosted Ollama (another machine):
# OLLAMA_BASE_URL=http://100.x.x.x:11434
# OLLAMA_API_KEY=only_if_that_server_requires_bearer

# Optional: OpenAI cloud instead of Ollama (different product)
# CPP_ALLOW_OPENAI=true
# CPP_LLM_BACKEND=openai
# Agent_Broncos_API_Key=
# OPENAI_API_KEY=
# CPP_OPENAI_MODEL=gpt-4o-mini

# LLM HTTP timeouts (seconds)
# CPP_LLM_CONNECT_TIMEOUT=10
# CPP_LLM_READ_TIMEOUT=120
# CPP_LLM_MAX_RETRIES=0

# --- Request budget (stability on small models: gemma3:4b, etc.) ---
# Ollama OpenAI API: caps KV cache for long prompts. Try 2048 if you still hit limits.
CPP_OLLAMA_NUM_CTX=4096
CPP_MAX_TOOL_ROUNDS=1
CPP_DEFAULT_TOP_K=4
CPP_MAX_TOP_K=6
CPP_FAISS_PREFETCH_K=12
CPP_MAX_CHUNK_CHARS=480
CPP_EXCERPT_WINDOW_CHARS=900
CPP_MAX_CONVERSATION_MESSAGES=4

# Local STT (record → upload → /api/transcribe) — use tiny on low-RAM laptops
# CPP_WHISPER_MODEL_SIZE=tiny
# CPP_WHISPER_DEVICE=cpu
# CPP_WHISPER_COMPUTE_TYPE=int8
# CPP_WHISPER_WARMUP=true

# Optional: campus pulse (n8n → ingest) + LLM tool get_student_pulse
# CPP_ENABLE_PULSE_TOOL=true
# CPP_PULSE_INGEST_SECRET=change-me-long-random
# CPP_PULSE_FILE=/absolute/path/to/_data/pulse/latest.json
# CPP_PULSE_URL=https://example.com/pulse.json

# Optional corpus / index paths
# CPP_CORPUS_DIR=/absolute/path/to/_data/Corpus/itc2026_ai_corpus
# CPP_INDEX_DIR=/absolute/path/to/_data/index
# CPP_USE_RERANKER=true
# HF_TOKEN=
