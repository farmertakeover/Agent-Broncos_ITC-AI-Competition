# Flask loads `.env` only (see app/__init__.py load_dotenv). This file is a template — copy to `.env`:
#   cp .env.example .env
# =============================================================================
# Chat LLM: OpenAI (ChatGPT API)
# Keys: https://platform.openai.com/api-keys
# =============================================================================
CPP_LLM_BACKEND=openai
CPP_ALLOW_OPENAI=true
# Never commit real keys. Use `.env` (gitignored) or CI/GitHub secrets.
OPENAI_API_KEY=replace_with_your_openai_api_key
# Must match an OpenAI chat model id from your account (e.g. gpt-5-mini).
CPP_OPENAI_MODEL=gpt-5-mini
# Optional: only if your model accepts it (gpt-5* often allows default only — leave unset).
# CPP_OPENAI_TEMPERATURE=1

# Verify:  python run.py  then  curl -sS http://127.0.0.1:5000/api/health | python3 -m json.tool
# Expect: llm_backend "openai", openai_configured true (when key is set).

# =============================================================================
# Optional: Ollama instead of OpenAI (comment out CPP_LLM_BACKEND=openai block above)
# =============================================================================
# CPP_LLM_BACKEND=ollama
# CPP_ALLOW_OPENAI=false
# OLLAMA_BASE_URL=https://ollama.com
# OLLAMA_API_KEY=
# OLLAMA_MODEL=gemma3:4b
# Local: OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM HTTP timeouts (seconds)
# CPP_LLM_CONNECT_TIMEOUT=10
# CPP_LLM_READ_TIMEOUT=120
# CPP_LLM_MAX_RETRIES=0

# --- Request budget (retrieval + tool payload size) ---
# Ollama only (ignored when CPP_LLM_BACKEND=openai):
# CPP_OLLAMA_NUM_CTX=4096
CPP_MAX_TOOL_ROUNDS=1
CPP_DEFAULT_TOP_K=4
CPP_MAX_TOP_K=6
CPP_FAISS_PREFETCH_K=12
CPP_MAX_CHUNK_CHARS=480
CPP_EXCERPT_WINDOW_CHARS=900
CPP_MAX_CONVERSATION_MESSAGES=4

# Local STT (record → upload → /api/transcribe) — use tiny on low-RAM laptops
# CPP_WHISPER_MODEL_SIZE=tiny
# CPP_WHISPER_DEVICE=cpu
# CPP_WHISPER_COMPUTE_TYPE=int8
# CPP_WHISPER_WARMUP=true

# Optional: campus pulse (n8n → ingest) + LLM tool get_student_pulse
# CPP_ENABLE_PULSE_TOOL=true
# CPP_PULSE_INGEST_SECRET=change-me-long-random
# CPP_PULSE_FILE=/absolute/path/to/_data/pulse/latest.json
# CPP_PULSE_URL=https://example.com/pulse.json

# Optional corpus / index paths
# CPP_CORPUS_DIR=/absolute/path/to/_data/Corpus/itc2026_ai_corpus
# CPP_INDEX_DIR=/absolute/path/to/_data/index
# CPP_USE_RERANKER=true
# HF_TOKEN=

# =============================================================================
# Optional: Langbly translation + OpenWeatherMap (server routes /translate, /weather)
# =============================================================================
# Agent_Broncos_Language_Translation=your_langbly_api_key
# Agent_Broncos_Weather_API=your_openweathermap_api_key
# Endpoints (also mirrored under /api/translate and /api/weather):
#   GET  /weather?city=Pomona
#   POST /translate  JSON {"text":"...","target":"en"}

# RAG embeddings (local sentence-transformers) — NOT the OpenAI chat model.
# Re-run `python scripts/build_index.py` only if you change CPP_EMBEDDING_MODEL, chunking, or corpus content.
# Default `all-MiniLM-L6-v2`: fine on CPU (roughly a few hundred MB–1 GB RAM); GPU optional if PyTorch sees CUDA.
# CPP_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# =============================================================================
# Homepage dashboard: GET /api/dashboard (RSS + ICS + pulse)
# =============================================================================
# Flask session signing (recommended for dashboard prefs in session)
# FLASK_SECRET_KEY=use-a-long-random-string-in-production
#
# Official RSS feeds (override if URLs change). News defaults to CPP Polycentric when unset.
# CPP_DASHBOARD_RSS_NEWS=https://polycentric.cpp.edu/feed/
# CPP_DASHBOARD_RSS_EVENTS=
# CPP_DASHBOARD_RSS_ANNOUNCE=
# MyBar ICS for Upcoming events: defaults to https://mybar.cpp.edu/events.ics when unset.
# Set to empty string to disable: CPP_DASHBOARD_MYBAR_ICS=
# CPP_DASHBOARD_MYBAR_ICS=https://mybar.cpp.edu/events.ics
# CPP_DASHBOARD_FETCH_TIMEOUT=6
# Unit tests / CI: skip outbound RSS fetches
# CPP_DASHBOARD_SKIP_REMOTE=true
# Optional: skip HEAD checks for campus link tiles (CPP_DASHBOARD_SKIP_REMOTE also skips checks)
# CPP_DASHBOARD_LINK_CHECK=false
#
# Reddit in pulse/dashboard: server fetches public JSON by default (often blocked from cloud IPs).
# CPP_PULSE_REDDIT_ENABLED=true
# CPP_PULSE_REDDIT_LIVE_FETCH=false
# When CPP_PULSE_REDDIT_LIVE_FETCH=false, populate reddit_cpp.items via n8n + POST /api/student-pulse/ingest only.
# CPP_REDDIT_JSON_URL=https://www.reddit.com/r/CalPolyPomona/new.json?limit=10
# CPP_REDDIT_USER_AGENT=AgentBroncos-Pulse/1.0
# CPP_REDDIT_FETCH_TIMEOUT=8
# Minimal ingest body example (requires CPP_PULSE_INGEST_SECRET):
#   {"schema_version":1,"reddit_cpp":{"items":[{"title":"Example","url":"https://www.reddit.com/r/CalPolyPomona/","subreddit":"CalPolyPomona"}]}}

# =============================================================================
# Translation (Langbly) — optional UI + chat string translation
# =============================================================================
# Agent_Broncos_Language_Translation=your_langbly_api_key
